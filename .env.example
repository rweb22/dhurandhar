# LLM Provider Configuration
# Choose: openai, anthropic
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Database Configuration
DATABASE_PATH=./data/sources.db
DATABASE_TYPE=sqlite  # sqlite or duckdb

# MCP Server Configuration
MCP_HOST=localhost
MCP_PORT=8765

# Data Fetching Configuration
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
REQUEST_TIMEOUT_SECONDS=30
MAX_CONCURRENT_REQUESTS=5

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/pnp-assistant.log

# User Preferences
DEFAULT_PERSONA=compliance
USER_EXPERIENCE_LEVEL=beginner  # beginner, intermediate, expert
